# HeyDPE mobile — public client config.
# EXPO_PUBLIC_* vars are inlined into the app bundle at build time.
# Copy this file to apps/mobile/.env and fill in the values.
# The Supabase anon key is client-safe (RLS-protected) — not a secret.

EXPO_PUBLIC_SUPABASE_URL=https://pvuiwwqsumoqjepukjhz.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Override to point at a local/staging API; defaults to production.
EXPO_PUBLIC_API_URL=https://aviation-oral-exam-companion.vercel.app
