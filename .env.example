# =============================================================================
# HeyDPE — Environment Variables
# =============================================================================
# Copy to .env.local and fill in values.
# For staging, also see .env.staging.example.

# --- Environment identification ---
# Set explicitly to override auto-detection.
# Values: local | staging | production
# If unset, falls back to VERCEL_ENV mapping or 'local'.
# NEXT_PUBLIC_APP_ENV=local

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (Claude API for examiner) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (TTS fallback + embeddings) ---
OPENAI_API_KEY=sk-...

# --- PostHog (server-side analytics — admin dashboard only) ---
POSTHOG_PERSONAL_API_KEY=phx_...

# --- Resend (email service — outbound + inbound) ---
RESEND_API_KEY=re_...
RESEND_INBOUND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...
EMAIL_FORWARD_TO=your-personal@email.com

# --- Upstash Redis (distributed rate limiting — optional but recommended for production)
# Create a free database at https://console.upstash.com and copy REST API credentials.
# If not configured, rate limiting falls back to in-memory (warning will be logged).
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# --- Cron Jobs (Vercel scheduled functions)
# Set a strong random secret for authenticating cron endpoints.
# CRON_SECRET=your-random-secret-here
